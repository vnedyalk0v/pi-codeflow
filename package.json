{
  "name": "pi-codeflow",
  "version": "0.1.0",
  "description": "Pi package for consistent AI coding workflows",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "ai-coding-agent",
    "coding-workflow",
    "developer-tools",
    "pull-request",
    "conventional-commits",
    "github-actions"
  ],
  "scripts": {
    "check": "npm run check:json && npm run check:text && npm run check:docs && npm run typecheck && npm test",
    "check:json": "node scripts/check-json.mjs",
    "check:text": "node scripts/check-text-safety.mjs",
    "check:docs": "node scripts/check-docs-format.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
