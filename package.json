{
  "name": "pi-codeflow",
  "version": "0.1.0",
  "description": "Pi package for consistent AI coding workflows",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "ai-coding-agent",
    "coding-workflow",
    "developer-tools",
    "pull-request",
    "conventional-commits",
    "github-actions"
  ],
  "scripts": {
    "check": "npm run check:json && npm run check:text && npm run check:docs",
    "check:json": "node scripts/check-json.mjs",
    "check:text": "node scripts/check-text-safety.mjs",
    "check:docs": "node scripts/check-docs-format.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  }
}
