{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vnedyalk0v/pi-codeflow/schemas/commit-payload.schema.json",
  "title": "Codeflow commit payload",
  "type": "object",
  "required": ["type", "summary", "changes", "verification", "risk"],
  "properties": {
    "type": { "type": "string" },
    "scope": { "type": "string" },
    "summary": { "type": "string" },
    "context": { "type": "string" },
    "changes": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "array", "items": { "type": "string" } },
    "risk": { "type": "string" },
    "refs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
