{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vnedyalk0v/pi-codeflow/schemas/final-report.schema.json",
  "title": "Codeflow final report",
  "description": "Structured payload for final delivery reports.",
  "type": "object",
  "required": [
    "summary",
    "finalPhase",
    "changedFiles",
    "checks",
    "issues",
    "risks"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "finalPhase": {
      "type": "string",
      "enum": [
        "idle",
        "initialized",
        "branch_prepared",
        "planning",
        "implementing",
        "local_checks",
        "self_review",
        "fixing_local_findings",
        "ready_to_commit",
        "committed",
        "pr_opened",
        "ci_waiting",
        "review_triage",
        "fixing_review_findings",
        "verified",
        "final_reported",
        "blocked",
        "emergency"
      ]
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "result"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped",
              "not_run"
            ]
          },
          "details": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pullRequest": {
      "type": "string"
    },
    "reviewComments": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "followUp": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "emergencyOverride": {
      "type": "object",
      "required": [
        "used",
        "reason"
      ],
      "properties": {
        "used": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "backportPlan": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "used": {
                "const": true
              }
            },
            "required": [
              "used"
            ]
          },
          "then": {
            "required": [
              "backportPlan"
            ]
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
