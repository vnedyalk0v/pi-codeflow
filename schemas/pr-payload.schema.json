{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vnedyalk0v/pi-codeflow/schemas/pr-payload.schema.json",
  "title": "Codeflow PR payload",
  "description": "Structured payload supplied by the agent before Codeflow renders and opens or updates a PR.",
  "type": "object",
  "required": [
    "title",
    "body"
  ],
  "properties": {
    "title": {
      "type": "object",
      "required": [
        "type",
        "summary"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "feat",
            "fix",
            "hotfix",
            "refactor",
            "perf",
            "docs",
            "test",
            "chore",
            "ci",
            "build",
            "revert"
          ],
          "description": "Conventional PR title type."
        },
        "scope": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]*$",
          "description": "Optional component scope."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Short deterministic title summary."
        },
        "ticket": {
          "type": "string",
          "minLength": 1,
          "description": "Optional ticket ID rendered by configured title templates."
        }
      },
      "additionalProperties": false
    },
    "body": {
      "type": "object",
      "required": [
        "summary",
        "context",
        "changes",
        "risk",
        "rollback"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "changes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "verification": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Commands run or explicit skipped-check reasons. Required by default Codeflow policy."
        },
        "selfReview": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Agent self-review evidence. Required by default Codeflow policy."
        },
        "risk": {
          "type": "string",
          "minLength": 1
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        },
        "reviewerNotes": {
          "type": "string"
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Optional issue or ticket references rendered with Refs by default."
        }
      },
      "additionalProperties": false
    },
    "draft": {
      "type": "boolean"
    },
    "baseBranch": {
      "$ref": "#/$defs/gitBranchName",
      "description": "Optional PR base branch override."
    },
    "headBranch": {
      "$ref": "#/$defs/gitBranchName",
      "description": "Optional PR head branch override."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "gitBranchName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![-+])(?!refs/)(?!HEAD$)(?!@$)(?!/)(?!.*//)(?!.*\\s)(?!.*[\\u0000-\\u001f\\u007f])(?!.*\\.\\.)(?!.*@\\{)(?!.*[~^:?*\\[\\\\])(?!.*(?:^|/)\\.)(?!.*(?:^|/)[^/]*\\.lock(?:/|$))(?!.*[/.]$).+$",
      "description": "Codeflow git branch name. Rejects option-like, refspec-like, fully-qualified refs/, pseudo-ref, whitespace/control, and Git-invalid path component forms."
    }
  }
}
