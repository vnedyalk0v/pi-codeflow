{
  "$schema": "../../../schemas/codeflow.schema.json",
  "baseBranches": {
    "default": "main",
    "allowed": ["main"],
    "missingDefaultBehavior": "block"
  },
  "branching": {
    "defaultType": "feat",
    "slug": {
      "maxLength": 40
    }
  },
  "checks": [
    {
      "name": "unit tests",
      "command": "npm test",
      "timeoutMs": 120000
    }
  ],
  "pullRequest": {
    "baseBranch": "main"
  },
  "templates": {
    "pullRequest": "docs/custom-pr-template.md"
  }
}
